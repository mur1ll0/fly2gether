# Configuração de Porta e Ambiente
PORT=5000
NODE_ENV=development

# Banco de Dados MongoDB Atlas (Free Tier)
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/fly2gether?retryWrites=true&w=majority

# Autenticação JWT e Google OAuth
JWT_SECRET=sua-chave-secreta-jwt-super-segura-fly2gether
GOOGLE_CLIENT_ID=seu-google-client-id.apps.googleusercontent.com

# Notificações por E-mail (Resend API - https://resend.com)
RESEND_API_KEY=re_sua_chave_resend_aqui

# Provedor de Dados de Voos ao Vivo (Opções: 'googleflights', 'duffel', 'mock')
FLIGHT_PROVIDER=googleflights
SERPAPI_KEY=sua_chave_serpapi_google_flights
DUFFEL_API_TOKEN=sua_chave_duffel_api

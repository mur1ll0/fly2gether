{
  "name": "fly2gether",
  "version": "1.0.0",
  "description": "Sistema Inteligente de Busca de Voos Normais e Combinados (Fly Together) com Finais de Semana, Feriados e Férias Conjuntas",
  "main": "server/src/server.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix client\" \"npm run dev --prefix server\"",
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "build": "npm run build --prefix client",
    "start": "node server/src/server.js"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "google-auth-library": "^9.15.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "puppeteer": "^25.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
